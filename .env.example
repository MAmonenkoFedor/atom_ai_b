DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=atom_ai
POSTGRES_USER=atom_ai
POSTGRES_PASSWORD=atom_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql://atom_ai:atom_ai@localhost:5433/atom_ai

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
LLM_GATEWAY_TIMEOUT_MS=30000
LLM_GATEWAY_MAX_RETRIES=1
LLM_GATEWAY_ENABLE_FALLBACK=True
LLM_GATEWAY_MOCK_MODE=True
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_AI_MODEL=openai/gpt-4o-mini
AI_CHAT_MAX_TOKENS=800
AI_CHAT_HISTORY_LIMIT=20
AI_CHAT_RATE_LIMIT_USER_PER_MINUTE=20
AI_CHAT_RATE_LIMIT_COMPANY_PER_MINUTE=120
AI_SYSTEM_PROMPT=You are the ATOM AI assistant. Give concise, actionable and safe responses. Use only provided context and chat history.

SENTRY_DSN=
LOG_LEVEL=INFO

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=atom-ai

# Optional Fernet key (url-safe base64) for encrypting storage provider secrets at rest.
# Leave empty to derive from DJANGO_SECRET_KEY (rotating SECRET_KEY invalidates stored credentials).
# STORAGE_CREDENTIALS_FERNET_KEY=
